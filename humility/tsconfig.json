{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",

    "paths": {
      "lib/*": ["./source/lib/*"]
    },

    "allowJs": true,
    "checkJs": true,
    "maxNodeModuleJsDepth": 1,
    "noEmit": true,

    // "strict": true,
    "strictNullChecks": true,
  },
  "include": ["**/*"],
  "exclude": ["**/node_modules/**", "**/.build", "**/build", "**/temp", "**/legacy"]
}
