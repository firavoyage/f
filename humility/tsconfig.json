{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",

    "baseUrl": "./source",
    // "paths": {
    //   "lib/*": ["./source/lib/*"],
    //   "web/*": ["./source/web/*"],
    // },

    "allowJs": true,
    "checkJs": false,
    "maxNodeModuleJsDepth": 1,
    "noEmit": true,

    "jsx": "react-jsx",

    "strict": true,
    // "noImplicitAny": false, // override strict
    // "strictNullChecks": false,
    "skipLibCheck": true,
    "types": ["node"] // not to auto-scan the disk for hidden @types packages
  },
  "include": ["**/*"],
  "exclude": [
    // "**/temp",
    "**/.dist",
    "**/dist",
    "**/.build",
    "**/build",
    "**/legacy",
    "**/node_modules",
  ]
}
