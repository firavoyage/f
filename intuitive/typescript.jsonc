{
  "function": {
    "prefix": "f",
    "body": ["function ${1:name}(${2}) {", "  $0", "}"],
  },
  "export function": {
    "prefix": "ef",
    "body": ["export function ${1:name}(${2}) {", "  $0", "}"],
  },
  "export const": {
    "prefix": "ec",
    "body": ["export const ${1:name} = ${2}"],
  },
}
