variant(type, value)
  '[' + type + '="' + value + '"], [data-' + type + '="' + value + '"]'

modes = {
  theme: 'light' 'dark'
}

for type, values in modes
  for value in values
    define(value, variant(type, value))

foo = 'white'

{dark}
  foo = black

body
  background-color foo
